# Lumen 官网 Pages Function 环境变量与 Secret 清单（web-design.md §9.1）
#
# 用法：
#   - 本地开发：复制为 `.dev.vars`（已 gitignore），本地运行时注入。
#     # EDGEONE-VERIFY: EdgeOne 本地开发的环境变量注入方式以官方 CLI/控制台为准。
#   - 生产/预览：非机密项写入 edgeone.json [vars] 或 EdgeOne 控制台环境变量；
#     机密项（OIDC_CLIENT_SECRET / SESSION_ENC_KEY）在 EdgeOne 控制台设为「加密变量」注入。
#
# 安全红线：client_secret 绝不进前端产物/仓库/桌面（web-design.md §8.1）。
# 本文件仅示例，不含任何真实机密；域名 example.com 为占位，保持可配置。

# --- IdP（OAuth2/OIDC）端点 ---
OIDC_ISSUER=https://auth.example.com/realms/lumen
OIDC_AUTHORIZE_URL=https://auth.example.com/realms/lumen/protocol/openid-connect/auth
OIDC_TOKEN_URL=https://auth.example.com/realms/lumen/protocol/openid-connect/token
OIDC_USERINFO_URL=https://auth.example.com/realms/lumen/protocol/openid-connect/userinfo

# --- 官网 OIDC client（confidential） ---
OIDC_CLIENT_ID=lumen-website
# Secret：仅服务端加密变量（EdgeOne 控制台），绝不进前端/仓库。本地用 .dev.vars。
OIDC_CLIENT_SECRET=replace-with-confidential-client-secret

# 令 access_token 的 aud 含此值（= 服务端 LUMEN_OAUTH_AUDIENCE）
OIDC_AUDIENCE=lumen-api

# --- redirect_uri（须在 IdP 登记，web-design.md §3.3） ---
OIDC_DESKTOP_REDIRECT_URI=https://example.com/desktop/callback
OIDC_WEB_REDIRECT_URI=https://example.com/auth/callback

# --- 官网基址 / 下载清单 ---
WEB_BASE_URL=https://example.com
UPDATES_LATEST_URL=https://chat.example.com/updates/latest.json

# --- 网页会话 cookie 加密/签名密钥（账户中心）---
# Secret：base64（≥32 字节随机）。生成示例：openssl rand -base64 32
SESSION_ENC_KEY=replace-with-base64-32byte-random-key
