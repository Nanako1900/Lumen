# Lumen 服务端环境变量示例（占位值，禁止填入真实密钥）
# 复制为 .env（本地）或在 Coolify → Environment Variables 注入。
# 服务端启动时校验必填项，缺失即 fail-fast 退出（config.Load）。
# 契约来源：docs/design/protocol-design.md §1.3 / server-design.md §6.1 / §10
#
# 【必填清单】以下变量缺失/无效 → 启动即报 "缺失/无效环境变量: ..." 并退出：
#   LUMEN_OAUTH_ISSUER / LUMEN_OAUTH_JWKS_URL / LUMEN_OAUTH_AUDIENCE /
#   LUMEN_OWNER_SUBJECTS / LUMEN_LISTEN_ADDR / LUMEN_DATABASE_URL /
#   LUMEN_PUBLIC_IP / LUMEN_WEBRTC_UDP_PORT /
#   LUMEN_OAUTH_CLIENT_ID / LUMEN_OAUTH_CLIENT_SECRET /
#   LUMEN_OAUTH_DESKTOP_REDIRECT_URI / LUMEN_OAUTH_WEB_REDIRECT_URI /
#   LUMEN_WEB_BASE_URL / LUMEN_SESSION_ENC_KEY / LUMEN_REFRESH_ENC_KEY

# ---- OIDC / 资源服务器验签（本地 JWKS 验 access_token）----
# OIDC issuer（校验 access_token 的 iss，并作 OIDC discovery 基址）
LUMEN_OAUTH_ISSUER=https://auth.example.com/realms/lumen
# JWKS 端点（本地验签公钥来源；须 HTTPS 且启动时可达，否则 fail-fast）
LUMEN_OAUTH_JWKS_URL=https://auth.example.com/realms/lumen/protocol/openid-connect/certs
# userinfo 端点（资料补齐兜底）；可选，缺省由 OIDC discovery 自 issuer 推导
LUMEN_OAUTH_USERINFO_URL=
# 期望的 aud 值（资源侧验 access_token 的 aud）
LUMEN_OAUTH_AUDIENCE=lumen-api
# owner 的 OAuth subject 列表，逗号分隔（owner 判定为配置态，不入库）
LUMEN_OWNER_SUBJECTS=replace-with-owner-sub-1,replace-with-owner-sub-2

# ---- 登录 broker（confidential OIDC client，#40 后并入服务端；必填）----
# confidential client id（broker 用；与资源侧的 aud 不同）
LUMEN_OAUTH_CLIENT_ID=lumen-web
# confidential client_secret（secret，仅服务端持有，绝不下发/落前端）
LUMEN_OAUTH_CLIENT_SECRET=replace-with-confidential-client-secret
# authorize / token 端点；可选，缺省由 OIDC discovery 自 issuer 推导
LUMEN_OAUTH_AUTHORIZE_URL=
LUMEN_OAUTH_TOKEN_URL=
# IdP 回调（均在服务端域 chat.*；须与 IdP 登记的 redirect_uri 完全一致）
LUMEN_OAUTH_DESKTOP_REDIRECT_URI=https://chat.example.com/desktop/callback
LUMEN_OAUTH_WEB_REDIRECT_URI=https://chat.example.com/auth/callback
# 官网 SPA 源（CORS 精确白名单 + /account 重定向目标；不带路径/末尾斜杠）
LUMEN_WEB_BASE_URL=https://example.com
# 两把 AES-256 密钥：各 base64 解码须为 32 字节，且【必须彼此不同】。
# 生成：openssl rand -base64 32（各跑一次，取不同值）。
# sessionEncKey 封账户中心 cookie；refreshEncKey 加密 refresh_token 于 DB 列。
LUMEN_SESSION_ENC_KEY=replace-with-base64-32B-key-A-openssl-rand-base64-32
LUMEN_REFRESH_ENC_KEY=replace-with-base64-32B-key-B-must-differ-from-A

# ---- 网络监听 ----
# HTTP/WS 监听地址（容器内必须绑 0.0.0.0，否则 Traefik 到不了容器）。
# 端口须与 Dockerfile EXPOSE/HEALTHCHECK、Coolify Ports Exposes、Health Check
# 端口【四处一致】。宿主机 8080 曾被占用返回 502，故统一用 8090。
LUMEN_LISTEN_ADDR=0.0.0.0:8090
# 对外 WS 地址（bootstrap.ws_url）；可选，缺省由请求 Host 头推导为 wss://<host>/ws
LUMEN_PUBLIC_WS_URL=wss://chat.example.com/ws

# ---- 数据库（PostgreSQL）----
# 连接串（DSN）。内部网络用 sslmode=disable；外部托管 PG 用 sslmode=require。
# 启动即 ping（5s 超时），不可达则 fail-fast——确保 PG 资源已就绪、服务名正确。
LUMEN_DATABASE_URL=postgres://lumen:replace-with-db-password@lumen-db:5432/lumen?sslmode=disable

# ---- WebRTC 媒体（Pion SFU，单 UDP 端口，绕过 Traefik）----
# VPS 公网 IP（SetNAT1To1IPs 宣告；替换 host 候选）
LUMEN_PUBLIC_IP=203.0.113.10
# WebRTC 媒体单 UDP 端口（须与 Dockerfile EXPOSE / Coolify Ports Mappings / 防火墙四处对齐）
LUMEN_WEBRTC_UDP_PORT=40000

# ---- 自动更新静态托管（[v1]，可选）----
# 更新文件目录（GET /updates/ 静态托管根）；缺省 /app/updates
LUMEN_UPDATES_DIR=/app/updates

# ---- 可观测性 ----
# 日志级别 debug/info/warn/error；缺省 info
LUMEN_LOG_LEVEL=info
